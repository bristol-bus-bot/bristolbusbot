# Install as /etc/bristolbusbot/backup.env with mode 0600.
# Values below are placeholders; never commit the real file.
BBB_BACKUP_CONFIG=/etc/bristolbusbot/backup.json
BBB_BACKUP_HEALTHCHECK_URL=https://hc-ping.com/REPLACE_WITH_BACKUP_CHECK_UUID
BBB_BACKUP_CHECK_HEALTHCHECK_URL=https://hc-ping.com/REPLACE_WITH_RESTIC_CHECK_UUID
AWS_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=auto
XDG_CACHE_HOME=/var/cache/bristolbusbot

/site/fbribuses.json
/bot/data/fbribuses.json
/pipeline/enrichment_report.json

# ── Build artefacts ──
node_modules/
dist/
*.tsbuildinfo
static/css/tailwind.css

# ── Python ──
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.test-tmp/
.ruff_cache/
.venv/
venv/


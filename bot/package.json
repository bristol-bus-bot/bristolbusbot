{
  "name": "bristol-bus-bot",
  "version": "1.0.0",
  "description": "Bristol Bus Bot - Real-time Bristol bus monitoring and social commentary",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:summary": "node dist/index.js --summary",
    "dev": "tsc --watch & node --watch dist/index.js",
    "clean": "rm -rf dist",
    "test-mode": "cross-env TEST_MODE=true NODE_ENV=test npm start",
    "test-summary": "cross-env TEST_MODE=true NODE_ENV=test npm run start:summary",
    "windows-test": "cross-env TEST_MODE=true NODE_ENV=test PORT=3001 npm run build && npm start",
    "windows-summary": "cross-env TEST_MODE=true NODE_ENV=test PORT=3001 npm run build && npm run start:summary",
    "lint": "echo 'Linting not configured yet'",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "keywords": [
    "bristol",
    "bus",
    "transport",
    "real-time",
    "ai",
    "monitoring",
    "bluesky",
    "siri-vm"
  ],
  "author": "bristol-bus-bot",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@atproto/api": "^0.12.0",
    "@types/better-sqlite3": "^7.6.13",
    "agentkeepalive": "^4.5.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "fast-xml-parser": "^5.10.0",
    "luxon": "^3.4.0",
    "node-fetch": "^3.3.0",
    "sqlite3": "^6.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/luxon": "^3.3.0",
    "@types/node": "^20.8.0",
    "@types/sqlite3": "^3.1.0",
    "cross-env": "^7.0.3",
    "typescript": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bristol-bus-bot/bristolbusbot.git"
  },
  "bugs": {
    "url": "https://github.com/bristol-bus-bot/bristolbusbot/issues"
  },
  "homepage": "https://github.com/bristol-bus-bot/bristolbusbot#readme"
}
